{
  "name": "monthly-design-reports",
  "version": "1.0.0",
  "description": "Monthly design report manager for creative professionals",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && copy /Y electron\\splash.html dist-electron\\ && electron-builder --win",
    "build:mac": "tsc && vite build && cp electron/splash.html dist-electron/ && electron-builder --mac --x64 --arm64",
    "preview": "vite preview",
    "electron:rebuild": "electron-rebuild -f -w sql.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "archiver": "^8.0.0",
    "jimp": "^1.6.1",
    "jspdf": "^2.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sql.js": "^1.11.0",
    "uuid": "^10.0.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.designreports.app",
    "productName": "Design Reports",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
